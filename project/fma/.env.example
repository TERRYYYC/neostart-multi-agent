# Anthropic API Key — get yours at https://console.anthropic.com
# Copy this file to .env and fill in your key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Chat Mode Settings / 聊天模式配置 ──────────────
# Model provider: claude | codex | gemini
# 模型提供商：claude | codex | gemini
MODEL_PROVIDER=claude

# Claude model (sonnet, opus, haiku)
# Claude 模型选择
CLAUDE_MODEL=sonnet

# Server port / 服务器端口
PORT=3000
