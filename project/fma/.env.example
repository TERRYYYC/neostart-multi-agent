# Anthropic API Key — get yours at https://console.anthropic.com
# Copy this file to .env and fill in your key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Chat Mode Settings / 聊天模式配置 ──────────────
# Default model provider (can be overridden per-request via UI)
# 默认模型提供商（可通过 UI 在每次请求中覆盖）
# Options / 选项: claude | codex | gemini
MODEL_PROVIDER=claude

# Server port / 服务器端口
PORT=3000

# ── Claude Settings / Claude 配置 ──────────────────
# Claude model (sonnet, opus, haiku)
# Claude 模型选择
CLAUDE_MODEL=sonnet

# Custom Claude CLI binary path (optional)
# 自定义 Claude CLI 路径（可选）
# CLAUDE_PATH=claude

# ── Codex Settings / Codex 配置 ────────────────────
# Codex model (default: uses codex default)
# Codex 模型选择（默认：使用 codex 默认模型）
# CODEX_MODEL=gpt-5-codex

# Custom Codex CLI binary path (optional)
# 自定义 Codex CLI 路径（可选）
# CODEX_PATH=codex

# ── Gemini Settings / Gemini 配置 ──────────────────
# Gemini model (default: uses gemini default)
# Gemini 模型选择（默认：使用 gemini 默认模型）
# GEMINI_MODEL=

# Custom Gemini CLI binary path (optional)
# 自定义 Gemini CLI 路径（可选）
# GEMINI_PATH=gemini

# ── Agent Pipeline Cost Tiers / Agent Pipeline 成本分层 ──
# [Phase 2] Per-agent provider and model override
# 每个 Agent 可独立配置 provider 和 model（默认全用 Claude）

# Planner: 需要深度推理 → 默认 opus / Deep reasoning → default opus
# PLANNER_PROVIDER=claude
# PLANNER_MODEL=opus

# Coder: 平衡性价比 → 默认 sonnet / Balanced → default sonnet
# CODER_PROVIDER=claude
# CODER_MODEL=sonnet

# Reviewer: 结构化审查 → 默认 haiku / Structured review → default haiku
# REVIEWER_PROVIDER=claude
# REVIEWER_MODEL=haiku
